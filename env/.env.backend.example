# ─── Plagit Backend — Environment Configuration ───
# Copy this file: cp .env.example .env
# Then fill in real values for each variable.

# ── Server ──
PORT=3000
NODE_ENV=development                    # development | production

# ── Database (development — individual fields) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plagit
DB_USER=
DB_PASSWORD=

# ── Database (production — single connection string) ──
# DATABASE_URL=postgres://user:password@host:5432/plagit
# DB_SSL=true                           # set to "false" to disable SSL

# ── Authentication ──
# Generate a strong secret for production: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── CORS ──
# Comma-separated origins, or * for all (dev only)
# Production: https://app.plagit.com,https://admin.plagit.com
CORS_ORIGIN=*

# ── Email (Resend) ──
# Without this, password reset codes are logged to console only
# Get API key at: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# ── AI / CV Parsing (Anthropic Claude) ──
# Without this, CV upload returns raw text without AI extraction
# Get API key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
